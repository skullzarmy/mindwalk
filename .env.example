# Copy to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────────────
# SERVER-SIDE KEY BEHAVIOUR
# All keys below are optional.  If none are set the server starts in
# BYOK-only mode: users are guided through a 3-step in-browser setup wizard
# where they enter their own API key.  That key is stored in the browser's
# localStorage and used for direct client → provider calls; it is never sent
# to this server.
# ─────────────────────────────────────────────────────────────────────────────
# AI Provider selection
# Set AI_PROVIDER to one of: openai | anthropic | google | xai | digitalocean
#                             cloudflare | openrouter
# If omitted, the server auto-detects from whichever key below is set first.
# AI_PROVIDER=openai

# Maximum tokens the AI may return per response (keep low for concise replies).
AI_MAX_TOKENS=150

# ─────────────────────────────────────────────────────────────────────────────
# OpenAI  (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# ─────────────────────────────────────────────────────────────────────────────
# Anthropic  (https://console.anthropic.com/)
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# ANTHROPIC_MODEL=claude-haiku-4-5

# ─────────────────────────────────────────────────────────────────────────────
# Google Gemini  (https://aistudio.google.com/app/apikey)
# GOOGLE_API_KEY=your-key-here
# GOOGLE_MODEL=gemini-flash-lite-latest

# ─────────────────────────────────────────────────────────────────────────────
# xAI / Grok  (https://console.x.ai/)
# XAI_API_KEY=xai-your-key-here
# XAI_MODEL=grok-3-mini-latest

# ─────────────────────────────────────────────────────────────────────────────
# DigitalOcean GenAI  (OpenAI-compatible agent endpoint; server-only, no BYOK)
# DIGITALOCEAN_API_KEY=your-do-token-here
# DIGITALOCEAN_BASE_URL=https://<agent-id>.agents.digitalocean.app/api/v1
# DIGITALOCEAN_MODEL=deepseek-r1-distill-llama-70b

# ─────────────────────────────────────────────────────────────────────────────
# Cloudflare Workers AI  (https://dash.cloudflare.com/ → AI)
# CLOUDFLARE_API_KEY=your-cf-api-token-here
# CLOUDFLARE_ACCOUNT_ID=your-account-id-here
# CLOUDFLARE_MODEL=@cf/meta/llama-4-scout-17b-16e-instruct
#
# Optional: set CLOUDFLARE_GATEWAY_ID to route requests through the
# Cloudflare AI Gateway (OpenAI-compatible chat completions endpoint).
# https://developers.cloudflare.com/ai-gateway/usage/chat-completion/
# CLOUDFLARE_GATEWAY_ID=your-gateway-id-here

# ─────────────────────────────────────────────────────────────────────────────
# OpenRouter (unified billing, 200+ models)  (https://openrouter.ai/keys)
# OPENROUTER_API_KEY=sk-or-your-key-here
# OPENROUTER_MODEL=meta-llama/llama-4-maverick:free

# ─────────────────────────────────────────────────────────────────────────────
PORT=3001

# ─────────────────────────────────────────────────────────────────────────────
# Canonical URL used for Open Graph / Twitter Card meta tags in index.html.
# Set to the public root URL of your deployment (no trailing slash).
# This variable is read at two points:
#   1. Vite build time — the URL is embedded directly in dist/index.html.
#   2. Express server startup — if the placeholder survived the build (i.e.
#      the env var was absent during `npm run build`), the server injects the
#      value at runtime before caching the HTML.  This allows Docker/container
#      workflows where the URL is only known at deploy time.
# VITE_CANONICAL_URL=https://mindwalk.app

# ─────────────────────────────────────────────────────────────────────────────
# Cloudflare Web Analytics beacon token.
# Obtain from Cloudflare Dashboard → Analytics → Web Analytics.
# Leave unset to disable analytics tracking.
# VITE_CF_BEACON_TOKEN=your-beacon-token-here
