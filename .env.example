# Copy to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────────────
# AI Provider selection
# Set AI_PROVIDER to one of: openai | anthropic | google | xai | digitalocean
#                             cloudflare | openrouter
# If omitted, the server auto-detects from whichever key below is set first.
# AI_PROVIDER=openai

# Maximum tokens the AI may return per response (keep low for concise replies).
AI_MAX_TOKENS=150

# ─────────────────────────────────────────────────────────────────────────────
# OpenAI  (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-3.5-turbo

# ─────────────────────────────────────────────────────────────────────────────
# Anthropic  (https://console.anthropic.com/)
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# ANTHROPIC_MODEL=claude-haiku-4-5

# ─────────────────────────────────────────────────────────────────────────────
# Google Gemini  (https://aistudio.google.com/app/apikey)
# GOOGLE_API_KEY=your-key-here
# GOOGLE_MODEL=gemini-1.5-flash

# ─────────────────────────────────────────────────────────────────────────────
# xAI / Grok  (https://console.x.ai/)
# XAI_API_KEY=xai-your-key-here
# XAI_MODEL=grok-3-mini

# ─────────────────────────────────────────────────────────────────────────────
# DigitalOcean GenAI  (OpenAI-compatible agent endpoint)
# DIGITALOCEAN_API_KEY=your-do-token-here
# DIGITALOCEAN_BASE_URL=https://<agent-id>.agents.digitalocean.app/api/v1
# DIGITALOCEAN_MODEL=n8n-meta-llama-3-1-70b-instruct

# ─────────────────────────────────────────────────────────────────────────────
# Cloudflare Workers AI  (https://dash.cloudflare.com/ → AI)
# CLOUDFLARE_API_KEY=your-cf-api-token-here
# CLOUDFLARE_ACCOUNT_ID=your-account-id-here
# CLOUDFLARE_MODEL=@cf/meta/llama-3.1-8b-instruct

# ─────────────────────────────────────────────────────────────────────────────
# OpenRouter (unified billing, 200+ models)  (https://openrouter.ai/keys)
# OPENROUTER_API_KEY=sk-or-your-key-here
# OPENROUTER_MODEL=openai/gpt-3.5-turbo

# ─────────────────────────────────────────────────────────────────────────────
PORT=3001
